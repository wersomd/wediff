# ─── Database ───
# Local dev uses the Dockerized Postgres from docker-compose.yml (run: docker compose up -d).
# Local Postgres has no pooler, so DIRECT_URL == DATABASE_URL.
DATABASE_URL="postgresql://wediff:wediff@localhost:5434/wediff?schema=public"
DIRECT_URL="postgresql://wediff:wediff@localhost:5434/wediff?schema=public"
#
# For a hosted Supabase deployment later, use the pooled URL for DATABASE_URL
# (port 6543, ?pgbouncer=true) and the direct URL (port 5432) for DIRECT_URL.

# ─── Auth.js ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# ─── Single-user seed credentials (used by prisma/seed.ts only) ───
APP_USER_EMAIL="you@wediff.kz"
APP_USER_PASSWORD="change-me"

# ─── Storage (wired up in Phase 6) ───
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="wediff"

# Приём заявок с внешних сайтов
LEADS_ALLOWED_ORIGIN=https://wersomd.github.io
LEADS_INBOUND_TOKEN=            # опционально: базовый барьер (токен виден в клиентском JS)
# Telegram-уведомление о новой заявке
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Антиспам (все опционально, есть дефолты)
LEADS_RATE_LIMIT=5             # макс. заявок с одного IP за окно
LEADS_RATE_WINDOW_S=60         # длина окна rate-limit, сек
LEADS_MIN_FILL_MS=2000         # быстрее заполнил форму — считаем ботом
